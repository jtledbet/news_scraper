<nav class="navbar navbar-inverse" id="main-nav">
  <div class="container-fluid">
    <ul class="nav navbar-nav">
      <li><a class="btn" href="/" title="Reload articles already saved in your database">Refresh Results</a></li>
      <li><a class="btn" id="scrape-btn" title="Fetch the latest top stories from Hacker News and save them to your database"><img id="icon" src="../../assets/images/flame.png">Populate! <img id="icon" src="../../assets/images/flame.png"></a></li>
      <li><a class="btn" id="clear-btn" title="Clear articles from view — does not delete them from the database">Clear Results!</a></li>
      <li><a class="btn" id="favorites-btn" title="Show only articles you have starred">★ Favorites</a></li>
    </ul>
  </div>
</nav>

<div class="jumbotron text-center">
  <div class="caption">
    <h1>HN Reader</h1>
    <h5>Hacker News stories, saved to your own database with personal notes.</h5>
  </div>
</div>

<div id="categories-bar" class="text-center">
  <div id="category-buttons"></div>
  <div id="search-group">
    <input type="text" id="search-input" placeholder="Search Hacker News...">
    <button class="btn" id="search-submit" title="Search HN stories — results are scoped to the active tab">Search</button>
  </div>
  <div id="search-label">
    <button class="btn" id="save-tab-btn" title="Save this search as a tab" style="display:none">+ Save as tab</button>
  </div>
</div>

<div class="container-fluid wrapper">
  <div id="articles"></div>
</div>

<!-- Note modal -->
<div class="modal fade" id="note-modal" tabindex="-1" role="dialog">
  <div class="modal-dialog" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <button type="button" class="close" data-dismiss="modal">&times;</button>
        <h4 class="modal-title" id="modal-article-title"></h4>
      </div>
      <div class="modal-body">
        <input id="titleinput" name="title" placeholder="Note title...">
        <textarea id="bodyinput" name="body" placeholder="Note body..."></textarea>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn" data-dismiss="modal">Cancel</button>
        <button class="btn" id="savenote" title="Save this note to the database">Save Note</button>
      </div>
    </div>
  </div>
</div>

<footer class="footer">
  <div class="container">
    <p><br>© Jon Ledbetter<br><a href="https://github.com/jtledbet/news_scraper">GitHub</a></p>
  </div>
</footer>

